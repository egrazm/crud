<a href="/topics">← Volver</a>
<h2>Editar tema</h2>

<form action="/topics/<%= topic.id %>/update" method="POST" class="card" style="display:flex; flex-direction:column; gap:8px; max-width:640px;">
  <label>Título</label>
  <input type="text" name="title" value="<%= topic.title %>" required />

  <label>Descripción</label>
  <textarea name="description"><%= topic.description %></textarea>

  <button type="submit">💾 Guardar cambios</button>
</form>
